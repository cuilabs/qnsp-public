{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rootDir": "src",
		"paths": {
			"@qnsp/shared-kernel": ["packages/shared-kernel/dist/index.d.ts"],
			"@qnsp/shared-kernel/errors": ["packages/shared-kernel/dist/errors/index.d.ts"],
			"@qnsp/shared-kernel/errors/http-client": [
				"packages/shared-kernel/dist/errors/http-client.d.ts"
			]
		},
		"composite": true,
		"tsBuildInfoFile": "tsconfig.tsbuildinfo"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "build"]
}
