{
	"name": "@cuilabs/liboqs-native",
	"version": "0.15.1",
	"type": "commonjs",
	"license": "BUSL-1.1",
	"description": "Native liboqs bindings wrapper for the QNSP platform.",
	"liboqsVersion": "0.15.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"files": [
		"dist/**/*",
		"prebuilds/**/*"
	],
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json && pnpm run check-dist",
		"build:debug": "node-gyp rebuild --debug",
		"build:native": "node ./tools/build.js",
		"check-dist": "node ./tools/check-dist.js",
		"lint": "biome check src tools vendor/path-key-shim.js",
		"prepare": "pnpm run check-dist",
		"prepublishOnly": "pnpm run build && pnpm run build:native",
		"test": "echo 'Run smoke tests via @cuilabs/qnsp-cryptography'",
		"typecheck": "tsc --project tsconfig.json --noEmit",
		"install": "node ./tools/install.js"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"node-addon-api": "^8.7.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"node-gyp": "^12.2.0",
		"prebuildify": "^6.0.1",
		"typescript": "^6.0.2"
	}
}
