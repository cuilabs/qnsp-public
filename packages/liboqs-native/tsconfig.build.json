{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"noEmit": false,
		"emitDeclarationOnly": false,
		"tsBuildInfoFile": null
	},
	"include": ["src/index.ts"],
	"exclude": ["src/addon.cc", "node_modules", "dist"]
}
