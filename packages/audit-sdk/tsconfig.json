{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rootDir": "src",
		"composite": true,
		"tsBuildInfoFile": "tsconfig.tsbuildinfo",
		"paths": {
			"@qnsp/observability": ["packages/observability/dist/index.d.ts"],
			"@qnsp/*": ["packages/*/src"],
			"@qnsp/app/*": ["apps/*/src"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "build"]
}
