{
	"name": "@qnsp/shared-kernel",
	"version": "0.1.0",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"description": "Domain primitives, error types, and cross-cutting utilities for the QNSP post-quantum security platform. Includes PostgreSQL helpers, JWT utilities, and typed error hierarchies.",
	"keywords": [
		"qnsp",
		"shared-kernel",
		"domain-primitives",
		"pqc",
		"post-quantum",
		"post-quantum-cryptography",
		"postgresql",
		"typescript",
		"nodejs",
		"quantum-safe",
		"zero-trust"
	],
	"homepage": "https://cloud.qnsp.cuilabs.io",
	"repository": {
		"type": "git",
		"url": "https://github.com/cuilabs/qnsp",
		"directory": "packages/shared-kernel"
	},
	"bugs": {
		"url": "https://github.com/cuilabs/qnsp/issues"
	},
	"exports": {
		"./package.json": "./package.json",
		"./db": {
			"types": "./dist/db.d.ts",
			"default": "./dist/db.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"default": "./dist/server.js"
		},
		"./errors": {
			"types": "./dist/errors/index.d.ts",
			"default": "./dist/errors/index.js"
		},
		"./errors/http-client": {
			"types": "./dist/errors/http-client.d.ts",
			"default": "./dist/errors/http-client.js"
		},
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"typesVersions": {
		"*": {
			"db": [
				"dist/db.d.ts"
			],
			"server": [
				"dist/server.d.ts"
			]
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsx watch src/index.ts",
		"lint": "biome check .",
		"test": "vitest run",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@qnsp/cryptography": "workspace:*",
		"@qnsp/pricing": "workspace:*",
		"@qnsp/resilience": "workspace:*",
		"nodemailer": "^8.0.4",
		"pg": "^8.20.0",
		"sql.js": "^1.14.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"@types/nodemailer": "^7.0.11",
		"@types/pg": "^8.20.0",
		"@types/sql.js": "^1.4.11",
		"fast-check": "^4.6.0",
		"vitest": "4.1.2"
	}
}
