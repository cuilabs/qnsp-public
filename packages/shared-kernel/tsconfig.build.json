{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"outDir": "dist",
		"rootDir": "src",
		"tsBuildInfoFile": "tsconfig.build.tsbuildinfo",
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "dist", "build"]
}
