{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rootDir": "src",
		"composite": true,
		"tsBuildInfoFile": "tsconfig.tsbuildinfo",
		"paths": {
			"@cuilabs/qnsp-observability": ["packages/observability/dist/index.d.ts"],
			"@cuilabs/qnsp-*": ["packages/*/src"],
			"@cuilabs/qnsp-app/*": ["apps/*/src"]
		}
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "build"]
}
