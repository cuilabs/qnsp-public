{
	"name": "@qnsp/pricing",
	"version": "0.1.0",
	"description": "Shared pricing types, tier limits, and add-on definitions for the QNSP platform.",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"homepage": "https://cloud.qnsp.cuilabs.io",
	"repository": {
		"type": "git",
		"url": "https://github.com/cuilabs/qnsp",
		"directory": "packages/pricing"
	},
	"bugs": {
		"url": "https://github.com/cuilabs/qnsp/issues"
	},
	"keywords": [
		"qnsp",
		"pricing",
		"tiers",
		"billing",
		"quotas",
		"add-ons",
		"typescript"
	],
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./tiers": {
			"types": "./dist/tiers.d.ts",
			"default": "./dist/tiers.js"
		},
		"./addons": {
			"types": "./dist/addons.d.ts",
			"default": "./dist/addons.js"
		}
	},
	"typesVersions": {
		"*": {
			"tiers": [
				"dist/tiers.d.ts"
			],
			"addons": [
				"dist/addons.d.ts"
			]
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"lint": "biome check .",
		"test": "vitest run",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"vitest": "4.1.2"
	}
}
