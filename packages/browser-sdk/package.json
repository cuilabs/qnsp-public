{
	"name": "@qnsp/browser-sdk",
	"version": "0.1.3",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"license": "Apache-2.0",
	"description": "Browser-compatible PQC encryption SDK for QNSP. Client-side encryption, signing, and key encapsulation using NIST FIPS 203/204/205 standards via @noble/post-quantum.",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"lint": "biome check .",
		"test": "vitest run",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"dependencies": {
		"@noble/hashes": "^2.0.1",
		"@noble/post-quantum": "^0.6.0",
		"@qnsp/kms-client": "workspace:*",
		"@qnsp/sdk-activation": "workspace:*",
		"@qnsp/storage-sdk": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"typescript": "^6.0.2",
		"vitest": "4.1.2"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"keywords": [
		"qnsp",
		"pqc",
		"post-quantum",
		"browser",
		"encryption",
		"ml-kem",
		"ml-dsa",
		"slh-dsa",
		"fips-203",
		"fips-204",
		"fips-205",
		"client-side-encryption",
		"noble",
		"sdk"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/cuilabs/qnsp",
		"directory": "packages/browser-sdk"
	},
	"homepage": "https://cloud.qnsp.cuilabs.io",
	"bugs": {
		"url": "https://github.com/cuilabs/qnsp/issues"
	},
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	]
}
